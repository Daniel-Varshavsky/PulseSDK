generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String?
  googleId     String?  @unique
  createdAt    DateTime @default(now())

  appMemberships AppMember[]
  experiments    Experiment[]
}

model App {
  id        String   @id @default(uuid())
  name      String
  apiKey    String   @unique @default(uuid())
  createdAt DateTime @default(now())

  members         AppMember[]
  experiments     Experiment[]
  users           User[]
}

model AppMember {
  id        String          @id @default(uuid())
  accountId String
  appId     String
  role      AppMemberRole   @default(COLLABORATOR)
  status    AppMemberStatus @default(ACTIVE)
  joinedAt  DateTime        @default(now())
  leftAt    DateTime?

  account Account @relation(fields: [accountId], references: [id])
  app     App     @relation(fields: [appId], references: [id])

  @@unique([accountId, appId])
}

model Experiment {
  id            String           @id @default(uuid())
  appId         String
  createdById   String
  name          String
  status        ExperimentStatus @default(ACTIVE)
  feedbackType  FeedbackType     @default(STAR_RATING)
  // Optional targeting: only devices on this app version or newer are
  // eligible for assignment. Null means unrestricted. Free-form dot-separated
  // string (Android versionName isn't guaranteed semver), compared segment by
  // segment — see lib/version.js.
  minAppVersion String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  app       App       @relation(fields: [appId], references: [id])
  createdBy Account   @relation(fields: [createdById], references: [id])
  variants  Variant[]
}

model Variant {
  id           String  @id @default(uuid())
  experimentId String
  name         String
  weight       Int
  choices      Json?
  metadata     Json?

  experiment        Experiment         @relation(fields: [experimentId], references: [id])
  feedbackResponses FeedbackResponse[]
  exposures         Exposure[]
}

model User {
  id             String   @id @default(uuid())
  appId          String
  externalUserId String?
  createdAt      DateTime @default(now())

  app               App                @relation(fields: [appId], references: [id])
  deviceTokens      DeviceToken[]
  feedbackResponses FeedbackResponse[]
  exposures         Exposure[]
  crashReports      CrashReport[]

  @@unique([appId, externalUserId])
}

model DeviceToken {
  id         String   @id @default(uuid())
  userId     String
  fcmToken   String   @unique
  updatedAt  DateTime @updatedAt
  lastSeenAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model FeedbackResponse {
  id         String       @id @default(uuid())
  userId     String
  variantId  String?
  type       FeedbackType
  value      Json
  comment    String?
  screenId   String?
  appVersion String?
  createdAt  DateTime     @default(now())

  user    User     @relation(fields: [userId], references: [id])
  variant Variant? @relation(fields: [variantId], references: [id])
}

// One row per (user, variant) — logged the first time a variant is resolved
// for a user in a given app process, not on every getVariant() call, so this
// counts "was shown", not "was rendered N times". Lets the Portal compute a
// real response rate (FeedbackResponse count / Exposure count) instead of
// just a raw response count with no denominator.
model Exposure {
  id        String   @id @default(uuid())
  userId    String
  variantId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  variant Variant @relation(fields: [variantId], references: [id])

  @@unique([userId, variantId])
}

// Crash reports are write-ahead-logged client-side (Room) before upload,
// same pattern as FeedbackResponse — a process that's about to die can't
// rely on a network call completing, so the SDK persists locally first and a
// WorkManager job uploads on the next safe opportunity.
model CrashReport {
  id         String   @id @default(uuid())
  userId     String
  message    String
  stackTrace String
  appVersion String?
  occurredAt DateTime

  user User @relation(fields: [userId], references: [id])
}

enum ExperimentStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

enum FeedbackType {
  STAR_RATING
  THUMBS
  TEXT
  MULTIPLE_CHOICE
}

enum AppMemberRole {
  OWNER
  COLLABORATOR
}

enum AppMemberStatus {
  ACTIVE
  REMOVED
}