DATABASE_URL="postgresql://user:password@localhost:5432/pulsesdk"

# Port the Express server listens on (defaults to 3000 if unset)
PORT=3000

# Secret used to sign/verify portal JWTs (auth.js, authJwt.js)
JWT_SECRET=

# Google OAuth client ID for "Sign in with Google" (auth.js)
# Leave unset to disable Google login — the endpoint returns 503 without it.
GOOGLE_CLIENT_ID=

# Firebase Admin SDK service account credentials, used to send push
# notifications (lib/firebase.js). All three must be set together — if any
# is missing, push notifications are disabled and /notifications/send
# returns a 503 instead of sending.
# Get these from Firebase Console > Project Settings > Service Accounts >
# Generate new private key.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep the \n escapes literal (don't replace with real newlines) — the app
# converts them back to newlines at startup.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"