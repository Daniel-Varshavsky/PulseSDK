<?xml version="1.0" encoding="utf-8"?>
<!-- Base stroke color/width here are placeholders — applyTheme() mutates
     and re-strokes this at runtime to match the active palette's accent
     color, the same way submitFeedbackButton's outline is themed. Right
     padding is widened to leave room for the arrow drawn on top of this
     in spinner_background.xml. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="8dp" />
    <stroke
        android:width="1dp"
        android:color="#FF9CA3AF" />
    <padding
        android:left="12dp"
        android:top="10dp"
        android:right="32dp"
        android:bottom="10dp" />
    <solid android:color="@android:color/transparent" />
</shape>
