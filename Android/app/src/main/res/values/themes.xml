<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.PulseSDK" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>

    <!-- Toolbar overflow popup (Switch Variant / Log out). Explicit
         day/night pair instead of relying on the Toolbar's own
         android:theme to resolve correctly — that mixed AppCompat/
         MaterialComponents inheritance is what caused unreadable text
         after a system day/night switch in the first place. -->
    <style name="PopupOverlay.PulseSDK" parent="ThemeOverlay.MaterialComponents.Light" />
</resources>